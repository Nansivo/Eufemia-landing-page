{
  "name": "eufemia-landing-page",
  "version": "1.0.0",
  "private": true,
  "description": "Eufemia Design System Portal - Expanded Landing Page Prototype",
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby serve -H 0.0.0.0 -p ${PORT:-9000}",
    "build": "gatsby build",
    "serve": "gatsby serve -H 0.0.0.0 -p ${PORT:-9000}",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "fetch-components": "node scripts/fetch-components.js",
    "prebuild": "npm run fetch-components",
    "studio": "cd studio && npm run dev",
    "studio:build": "cd studio && npm run build",
    "studio:deploy": "cd studio && npm run deploy"
  },
  "dependencies": {
    "@dnb/eufemia": "^10.46.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mdx-js/react": "^2.0.0",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.2",
    "gatsby": "^5.14.0",
    "gatsby-plugin-emotion": "^8.14.0",
    "gatsby-plugin-image": "^3.15.0",
    "gatsby-plugin-manifest": "^5.14.0",
    "gatsby-plugin-mdx": "^5.14.0",
    "gatsby-plugin-sass": "^6.14.0",
    "gatsby-plugin-sharp": "^5.15.0",
    "gatsby-source-filesystem": "^5.14.0",
    "gatsby-source-sanity": "^7.9.2",
    "gatsby-transformer-sharp": "^5.15.0",
    "glimm": "^0.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.62.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
